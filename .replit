modules = ["python-3.11"]
run = "uvicorn app.main:app --host 0.0.0.0 --port 8080"

[nix]
channel = "stable-23_11"

[[ports]]
localPort = 8080
externalPort = 80

[deployment]
deploymentTarget = "cloudrun"
run = ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port 8080"]

[agent]
expertMode = true
